# ── DeepSeek 云端（默认） ──────────────────────────────────────
DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_MODEL=deepseek-v4-flash   # 默认值，一般不用改

# ── 本地模型（对比实验用） ─────────────────────────────────────
# LLM_BACKEND=local                  # 切换到本地后端；不填默认 deepseek
# LOCAL_BASE_URL=http://192.168.x.x:11434/v1   # Windows 局域网 IP
# LOCAL_MODEL=qwen2.5-coder:7b-instruct        # Ollama 上拉取的模型名
