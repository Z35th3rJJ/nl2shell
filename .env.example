# ── DeepSeek 云端（默认） ──────────────────────────────────────
DEEPSEEK_API_KEY=your_api_key_here
# DEEPSEEK_MODEL=deepseek-v4-flash   # 默认值，一般不用改

# ── 本地模型（对比实验用） ─────────────────────────────────────
# LLM_BACKEND=local                  # 切换到本地后端；不填默认 deepseek
# LOCAL_BASE_URL=http://localhost:11434/v1     # Ollama 本机地址
# LOCAL_MODEL=qwen2.5-coder:1.5b               # 笔记本优先的小模型

# ── Bash / SSH（Linux 命令执行环境）─────────────────────────
# SHELL_EXECUTABLE=bash                         # 默认 bash
# BASH_PATH=C:\Program Files\Git\bin\bash.exe   # Windows 可显式指定 Git Bash
# SSH_CONFIG_PATH=~/.ssh/config                 # 仅读取 Host 别名，不读取私钥

# ── 默认运行方式 ─────────────────────────────────────────────
RUN_MODE=confirm                                # preview / confirm / auto-safe
SETUP_COMPLETE=false                            # 首次启动向导完成后自动改为 true
